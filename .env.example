# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080
GOOGLE_WEB_REDIRECT_URI=http://localhost:8080

# The name of the Google Calendar to use as the "scheduled calendar"
STASH_CALENDAR_NAME=Scheduled Calendar

# Anthropic
ANTHROPIC_API_KEY=

# PostgreSQL (Neon)
DATABASE_URL=

# Web frontend URL (used for CORS and OAuth redirects)
WEB_APP_URL=http://localhost:3000

# Session cookie signing secret — MUST be changed in production
SESSION_SECRET=change-me-in-production

# Deployment mode for authentication:
#   self_hosted = Google OAuth only (default, no Auth0 required)
#   auth0 = full Auth0-based hosted user login
SCHEDULER_DEPLOYMENT_MODE=self_hosted

# Auth0 (required only when SCHEDULER_DEPLOYMENT_MODE=auth0)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=

# How far back to look during onboarding (in days)
ONBOARDING_LOOKBACK_DAYS=60

# Polling interval for the email watcher (in seconds)
WATCHER_POLL_INTERVAL=300

# Agent runtime: "local" (default) or "e2b" (cloud sandbox)
AGENT_RUNTIME=local
# Required when AGENT_RUNTIME=e2b:
E2B_API_KEY=
E2B_TEMPLATE_ID=
CONTROL_PLANE_PUBLIC_URL=
CONTROL_PLANE_URL=

# Postmark (lifecycle emails)
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=sam@tryscheduled.com
POSTMARK_BOT_EMAIL=bot@tryscheduled.com
