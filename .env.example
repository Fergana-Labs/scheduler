# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/integrations/google/callback
GOOGLE_WEB_REDIRECT_URI=http://localhost:8080

# The name of the Google Calendar to use as the "stash calendar"
STASH_CALENDAR_NAME=Stash Calendar

# Anthropic
ANTHROPIC_API_KEY=

# PostgreSQL (Neon)
DATABASE_URL=

# Gmail push notifications (Google Cloud Pub/Sub)
GMAIL_PUBSUB_TOPIC=
# Shared secret to verify incoming webhook requests. Set this and append
# ?token=<value> to your Pub/Sub push subscription endpoint URL.
GMAIL_WEBHOOK_TOKEN=

# Web frontend URL (used for CORS and OAuth redirects)
WEB_APP_URL=http://localhost:3000

# Session cookie signing secret — MUST be changed in production
SESSION_SECRET=change-me-in-production

# How far back to look during onboarding (in days)
ONBOARDING_LOOKBACK_DAYS=60

# Agent runtime: "local" (default) or "e2b" (cloud sandbox)
AGENT_RUNTIME=local
# Required when AGENT_RUNTIME=e2b:
E2B_API_KEY=
E2B_TEMPLATE_ID=
CONTROL_PLANE_PUBLIC_URL=
